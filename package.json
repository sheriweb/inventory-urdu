{
  "name": "inventory-urdu",
  "version": "1.0.0",
  "private": true,
  "description": "Inventory Urdu — Multi-tenant Installment (Qist) Management System",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "build:shared": "npm run build -w @inventory-urdu/shared",
    "hostinger:build:api": "npm run build:shared && npm run db:generate -w @inventory-urdu/api && npm run build -w @inventory-urdu/api",
    "hostinger:build:web": "npm run build:shared && npm run build -w @inventory-urdu/web",
    "hostinger:db:push": "npm run db:push -w @inventory-urdu/api",
    "hostinger:db:seed": "npm run db:seed -w @inventory-urdu/api",
    "hostinger:install": "npm install",
    "hostinger:build": "npm install && npm run build:shared && npm run db:generate -w @inventory-urdu/api && rm -f apps/api/tsconfig.build.tsbuildinfo && NODE_OPTIONS='--max-old-space-size=768' npm run build -w @inventory-urdu/api && HOSTINGER_COMBINED=1 INTERNAL_API_URL=http://127.0.0.1:4001 NODE_OPTIONS='--max-old-space-size=768' npm run build -w @inventory-urdu/web",
    "start": "node scripts/hostinger-combined-start.mjs",
    "hostinger:start": "node scripts/hostinger-combined-start.mjs",
    "deploy:hostinger": "bash scripts/deploy-hostinger-ssh.sh"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.2",
    "@prisma/client": "^5.22.0",
    "@zxing/browser": "^0.1.5",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "clsx": "^2.1.1",
    "js-cookie": "^3.0.5",
    "lucide-react": "^1.17.0",
    "next": "^15.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tailwind-merge": "^2.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.4.0"
  },
  "engines": { "node": ">=20.0.0", "npm": ">=10.0.0" },
  "packageManager": "npm@10.0.0"
}
