# Database (MAMP MySQL — default for local dev)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock
DB_DATABASE=inventory_urdu_db
DB_USERNAME=root
DB_PASSWORD=root
DATABASE_URL=mysql://root:root@127.0.0.1:3306/inventory_urdu_db?socket=/Applications/MAMP/tmp/mysql/mysql.sock

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-inventory-urdu
JWT_REFRESH_SECRET=change-me-refresh-secret-inventory-urdu
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# API
NODE_ENV=development
API_PORT=4001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Super admin (seed)
SUPER_ADMIN_EMAIL=admin@inventory.local
SUPER_ADMIN_PASSWORD=Admin123!
SUPER_ADMIN_NAME=Super Admin

# Frontends
NEXT_PUBLIC_API_URL=http://localhost:4001/api/v1
