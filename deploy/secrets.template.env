# =============================================================================
# INVENTORY-URDU — HOSTINGER DEPLOYMENT SECRETS
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:  cp deploy/secrets.template.env deploy/secrets.env
#   2. Fill EVERY value below (remove __FILL_ME__ placeholders)
#   3. Tell Cursor: "secrets file ready — push and deploy"
#
# IMPORTANT: deploy/secrets.env is gitignored — never commit it!
#
# =============================================================================

# --- GITHUB (آپ repo بنا لیں، پھر URL یہاں لکھیں) ---
GITHUB_REPO_URL=__FILL_ME__https://github.com/YOUR_USERNAME/inventory-urdu.git
GITHUB_BRANCH=main
GITHUB_TOKEN=__FILL_ME__ghp_xxxxxxxxxxxxxxxxxxxx

# --- HOSTINGER API (optional — auto deploy ke liye) ---
# hPanel → Profile → API → Create token
HOSTINGER_API_TOKEN=__FILL_ME__
HOSTINGER_DOMAIN=paleturquoise-stork-447573.hostingersite.com

# --- HOSTINGER TEMPORARY DOMAINS (hPanel → Node.js Web App → domain) ---
# Web frontend URL (بغیر trailing slash)
WEB_URL=__FILL_ME__https://your-web.hostingersite.com
# API backend URL (بغیر trailing slash)
API_URL=__FILL_ME__https://your-api.hostingersite.com

# --- HOSTINGER MYSQL (hPanel → Databases → MySQL Databases → Create) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=__FILL_ME__
DB_USER=__FILL_ME__
DB_PASSWORD=__FILL_ME__
# DATABASE_URL — special chars in password کو URL-encode کریں (@ → %40 etc.)
DATABASE_URL=mysql://__USER__:__PASSWORD__@localhost:3306/__DBNAME__

# --- JWT SECRETS (random long strings — کم از کم 32 characters) ---
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=__FILL_ME__
JWT_REFRESH_SECRET=__FILL_ME__
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- SUPER ADMIN (production login — local wala use نہ کریں) ---
SUPER_ADMIN_EMAIL=__FILL_ME__admin@yourdomain.com
SUPER_ADMIN_PASSWORD=__FILL_ME__
SUPER_ADMIN_NAME="Super Admin"

# --- OPTIONAL: demo shop seed after deploy (1 = yes, 0 = no) ---
SEED_DEMO_DATA=1

# --- API production env (WEB_URL سے CORS_ORIGINS خود بھر جائے گا) ---
NODE_ENV=production
API_PREFIX=api/v1

# --- WEB production env ---
NEXT_PUBLIC_API_URL=__FILL_ME__https://your-api.hostingersite.com/api/v1

# =============================================================================
# HOSTINGER PANEL NOTES (یہ values panel میں manually بھی چاہیے)
# =============================================================================
#
# API App (Node.js Web App #1):
#   Framework: NestJS
#   Node version: 20
#   Root directory: . (repo root)
#   Install: npm ci
#   Build: npm run hostinger:build:api
#   Start: npm run start:prod -w @inventory-urdu/api
#   Port: $PORT (Hostinger auto)
#
# WEB App (Node.js Web App #2):
#   Framework: Next.js
#   Node version: 20
#   Root directory: . (repo root)
#   Install: npm ci
#   Build: npm run hostinger:build:web
#   Start: npm run start:hostinger -w @inventory-urdu/web
#   Port: $PORT (Hostinger auto)
#
# =============================================================================
