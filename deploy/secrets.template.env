# =============================================================================
# GITHUB ACTIONS SECRETS (repo → Settings → Secrets → Actions)
# =============================================================================
# FTP Node.js apps ke liye kaam NAHI karti — Hostinger API token use karein.

HOSTINGER_API_TOKEN=__FILL_ME__
HOSTINGER_DOMAIN=paleturquoise-stork-447573.hostingersite.com

# =============================================================================
# HOSTINGER NODE.JS ENV VARS (hPanel → website → Environment — ek dafa)
# =============================================================================

DATABASE_URL=mysql://testinven:YOUR_PASSWORD@localhost:3306/testinven
JWT_ACCESS_SECRET=__FILL_ME__
JWT_REFRESH_SECRET=__FILL_ME__
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
API_PREFIX=api/v1
CORS_ORIGINS=https://paleturquoise-stork-447573.hostingersite.com
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=__FILL_ME__
SUPER_ADMIN_NAME="Super Admin"
NEXT_PUBLIC_API_URL=https://paleturquoise-stork-447573.hostingersite.com/api/v1
HOSTINGER_COMBINED=1
INTERNAL_API_URL=http://127.0.0.1:4001
API_INTERNAL_PORT=4001
NODE_ENV=production

# Pehli deploy ke baad tables: npm run hostinger:db:push && npm run hostinger:db:seed
