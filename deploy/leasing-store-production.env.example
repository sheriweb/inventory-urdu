NODE_ENV=production
NPM_CONFIG_PRODUCTION=false
DATABASE_URL=mysql://DB_USER:DB_PASS@127.0.0.1:3306/DB_NAME
JWT_ACCESS_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string
JWT_ACCESS_EXPIRATION=30d
JWT_REFRESH_EXPIRATION=365d
API_PREFIX=api/v1
CORS_ORIGINS=https://leasing-store.com,https://www.leasing-store.com
SUPER_ADMIN_EMAIL=admin@leasing-store.com
SUPER_ADMIN_PASSWORD=change-me
SUPER_ADMIN_NAME="Super Admin"
NEXT_PUBLIC_API_URL=https://leasing-store.com/api/v1
HOSTINGER_COMBINED=1
INTERNAL_API_URL=http://127.0.0.1:4001
API_INTERNAL_PORT=4001
RUN_DB_SETUP=0
FORCE_DB_SETUP=0
